generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model PlatformAdmin {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("platform_admin")
  createdAt    DateTime @default(now())
}

model Company {
  id                  Int                  @id @default(autoincrement())
  name                String
  logo                String?
  industry            String?
  address             String?
  city                String?
  country             String?
  phone               String?
  website             String?
  companySize         String?
  regNumber           String?
  status              String               @default("active")
  planId              String?
  createdById         Int?
  createdAt           DateTime             @default(now())
  users               User[]
  employees           Employee[]
  departments         Department[]
  attendance          Attendance[]
  leaves              Leave[]
  leaveBalances       LeaveBalance[]
  payrolls            Payroll[]
  shiftSchedules      ShiftSchedule[]
  settings            CompanySettings?
  publicHolidays      PublicHoliday[]
  deductionRules      DeductionRule[]
  roles               Role[]
  salaryHistories     SalaryHistory[]
  performanceReviews  PerformanceReview[]
  jobPostings         JobPosting[]
  applicants          Applicant[]
  trainingPrograms    TrainingProgram[]
  trainingEnrollments TrainingEnrollment[]
  documents           Document[]
}

model User {
  id                   Int                 @id @default(autoincrement())
  companyId            Int
  name                 String
  email                String
  passwordHash         String
  role                 String
  isActive             Boolean             @default(true)
  resetToken           String?
  resetTokenExpiry     DateTime?
  sessionInvalidatedAt DateTime?
  createdAt            DateTime            @default(now())
  company              Company             @relation(fields: [companyId], references: [id])
  employee             Employee?
  salaryHistories      SalaryHistory[]
  performanceReviews   PerformanceReview[]
  jobPostings          JobPosting[]
  trainingPrograms     TrainingProgram[]
  documents            Document[]
  reviewsGiven         PerformanceReview[] @relation("ReviewerRelation")
  jobPostingsCreated   JobPosting[]        @relation("JobCreatorRelation")
  trainingsCreated     TrainingProgram[]   @relation("TrainingCreatorRelation")
  documentsUploaded    Document[]          @relation("DocumentUploaderRelation")
}

model Department {
  id               Int               @id @default(autoincrement())
  companyId        Int
  name             String
  headId           Int?
  status           String            @default("active")
  createdAt        DateTime          @default(now())
  company          Company           @relation(fields: [companyId], references: [id])
  employees        Employee[]
  shiftSchedules   ShiftSchedule[]
  jobPostings      JobPosting[]
  trainingPrograms TrainingProgram[]
}

model Employee {
  id                  Int                  @id @default(autoincrement())
  companyId           Int
  userId              Int                  @unique
  employeeCode        String
  designation         String?
  departmentId        Int?
  roleId              Int?
  salary              Float                @default(0)
  joinDate            DateTime             @default(now())
  status              String               @default("active")
  createdAt           DateTime             @default(now())
  phone               String?
  cnic                String?
  gender              String?
  employmentType      String               @default("full_time")
  company             Company              @relation(fields: [companyId], references: [id])
  user                User                 @relation(fields: [userId], references: [id])
  department          Department?          @relation(fields: [departmentId], references: [id])
  customRole          Role?                @relation(fields: [roleId], references: [id])
  attendance          Attendance[]
  leaves              Leave[]
  leaveBalances       LeaveBalance[]
  payrolls            Payroll[]
  salaryHistories     SalaryHistory[]
  performanceReviews  PerformanceReview[]
  trainingEnrollments TrainingEnrollment[]
  documents           Document[]
}

model Role {
  id          Int        @id @default(autoincrement())
  companyId   Int
  name        String
  description String?
  isDefault   Boolean    @default(false)
  scope       String     @default("all") // all | own_department
  permissions Json // stores permission object
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     Company    @relation(fields: [companyId], references: [id])
  employees   Employee[]

  @@unique([companyId, name])
}

model CompanySettings {
  id          Int      @id @default(autoincrement())
  companyId   Int      @unique
  workingDays String   @default("1,2,3,4,5") // 0=Sun,1=Mon,...,6=Sat
  timezone    String   @default("Asia/Karachi")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])
}

model PublicHoliday {
  id        Int      @id @default(autoincrement())
  companyId Int
  name      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
}

model ShiftSchedule {
  id           Int         @id @default(autoincrement())
  companyId    Int
  departmentId Int?
  name         String
  shiftStart   String
  shiftEnd     String
  gracePeriod  Int         @default(30)
  isActive     Boolean     @default(true)
  createdById  Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  company      Company     @relation(fields: [companyId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
}

model DeductionRule {
  id               Int      @id @default(autoincrement())
  companyId        Int
  type             String // LATE_ARRIVAL | HALF_DAY | UNAPPROVED_LEAVE
  deductPercentage Float    @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  company          Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, type])
}

model Attendance {
  id         Int       @id @default(autoincrement())
  companyId  Int
  employeeId Int
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     String
  createdAt  DateTime  @default(now())
  company    Company   @relation(fields: [companyId], references: [id])
  employee   Employee  @relation(fields: [employeeId], references: [id])
}

model Leave {
  id         Int      @id @default(autoincrement())
  companyId  Int
  employeeId Int
  leaveType  String
  startDate  DateTime
  endDate    DateTime
  days       Int
  reason     String?
  status     String   @default("pending")
  approvedBy Int?
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model LeaveBalance {
  id         Int      @id @default(autoincrement())
  companyId  Int
  employeeId Int
  leaveType  String
  total      Int      @default(0)
  used       Int      @default(0)
  remaining  Int      @default(0)
  year       Int
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Payroll {
  id                 Int      @id @default(autoincrement())
  companyId          Int
  employeeId         Int
  month              Int
  year               Int
  basic              Float
  houseRent          Float    @default(0)
  medicalAllowance   Float    @default(0)
  transportAllowance Float    @default(0)
  otherAllowances    Float    @default(0)
  bonus              Float    @default(0)
  overtimePay        Float    @default(0)
  grossSalary        Float    @default(0)
  withholdingTax     Float    @default(0)
  eobi               Float    @default(0)
  loanDeduction      Float    @default(0)
  otherDeductions    Float    @default(0)
  totalDeductions    Float    @default(0)
  netSalary          Float
  allowances         Float    @default(0)
  deductions         Float    @default(0)
  notes              String?
  status             String   @default("pending")
  autoGenerated      Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  company            Company  @relation(fields: [companyId], references: [id])
  employee           Employee @relation(fields: [employeeId], references: [id])
}

model SalaryHistory {
  id          Int      @id @default(autoincrement())
  companyId   Int
  employeeId  Int
  oldSalary   Float
  newSalary   Float
  amount      Float
  type        String // "increment" | "decrement"
  reason      String?
  changedById Int
  createdAt   DateTime @default(now())

  company   Company  @relation(fields: [companyId], references: [id])
  employee  Employee @relation(fields: [employeeId], references: [id])
  changedBy User     @relation(fields: [changedById], references: [id])
}

model PerformanceReview {
  id            Int      @id @default(autoincrement())
  companyId     Int
  employeeId    Int
  reviewerId    Int
  period        String // "monthly" | "quarterly" | "annual"
  reviewDate    DateTime
  kpis          Json // [{ title, rating, comment }]
  overallRating Float
  comments      String?
  status        String   @default("draft") // draft | submitted | acknowledged
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
  reviewer User     @relation("ReviewerRelation", fields: [reviewerId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])
  userId   Int?
}

model JobPosting {
  id           Int      @id @default(autoincrement())
  companyId    Int
  departmentId Int?
  title        String
  description  String?
  requirements String?
  salaryMin    Float?
  salaryMax    Float?
  status       String   @default("open") // open | closed
  createdById  Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company    Company     @relation(fields: [companyId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  createdBy  User        @relation("JobCreatorRelation", fields: [createdById], references: [id])
  applicants Applicant[]
  user       User?       @relation(fields: [userId], references: [id])
  userId     Int?
}

model Applicant {
  id            Int       @id @default(autoincrement())
  companyId     Int
  jobId         Int
  name          String
  email         String
  phone         String?
  status        String    @default("applied") // applied | shortlisted | interview | offered | hired | rejected
  interviewDate DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company Company    @relation(fields: [companyId], references: [id])
  job     JobPosting @relation(fields: [jobId], references: [id])
}

model TrainingProgram {
  id              Int      @id @default(autoincrement())
  companyId       Int
  departmentId    Int?
  title           String
  description     String?
  trainerName     String?
  startDate       DateTime
  endDate         DateTime
  maxParticipants Int?
  status          String   @default("upcoming") // upcoming | ongoing | completed
  createdById     Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company     Company              @relation(fields: [companyId], references: [id])
  department  Department?          @relation(fields: [departmentId], references: [id])
  createdBy   User                 @relation("TrainingCreatorRelation", fields: [createdById], references: [id])
  enrollments TrainingEnrollment[]
  user        User?                @relation(fields: [userId], references: [id])
  userId      Int?
}

model TrainingEnrollment {
  id          Int       @id @default(autoincrement())
  companyId   Int
  programId   Int
  employeeId  Int
  status      String    @default("pending") // pending | completed | failed
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  company  Company         @relation(fields: [companyId], references: [id])
  program  TrainingProgram @relation(fields: [programId], references: [id])
  employee Employee        @relation(fields: [employeeId], references: [id])
}

model Document {
  id           Int       @id @default(autoincrement())
  companyId    Int
  employeeId   Int
  type         String // CNIC | Degree | Contract | Experience Letter | Other
  name         String
  url          String
  expiryDate   DateTime?
  notes        String?
  uploadedById Int
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company    Company  @relation(fields: [companyId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])
  uploadedBy User     @relation("DocumentUploaderRelation", fields: [uploadedById], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
  userId     Int?
}
