generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model PlatformAdmin {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("platform_admin")
  createdAt    DateTime @default(now())
}

model Company {
  id             Int              @id @default(autoincrement())
  name           String
  logo           String?
  industry       String?
  address        String?
  status         String           @default("active")
  planId         String?
  createdById    Int?
  createdAt      DateTime         @default(now())
  users          User[]
  employees      Employee[]
  departments    Department[]
  attendance     Attendance[]
  leaves         Leave[]
  leaveBalances  LeaveBalance[]
  payrolls       Payroll[]
  shiftSchedules ShiftSchedule[]
  settings       CompanySettings?
  publicHolidays PublicHoliday[]
  deductionRules DeductionRule[]
}

model User {
  id                   Int       @id @default(autoincrement())
  companyId            Int
  name                 String
  email                String
  passwordHash         String
  role                 String
  isActive             Boolean   @default(true)
  sessionInvalidatedAt DateTime?
  createdAt            DateTime  @default(now())
  company              Company   @relation(fields: [companyId], references: [id])
  employee             Employee?
}

model Department {
  id             Int             @id @default(autoincrement())
  companyId      Int
  name           String
  headId         Int?
  status         String          @default("active")
  createdAt      DateTime        @default(now())
  company        Company         @relation(fields: [companyId], references: [id])
  employees      Employee[]
  shiftSchedules ShiftSchedule[]
}

model Employee {
  id            Int            @id @default(autoincrement())
  companyId     Int
  userId        Int            @unique
  employeeCode  String
  designation   String?
  departmentId  Int?
  salary        Float          @default(0)
  joinDate      DateTime       @default(now())
  status        String         @default("active")
  createdAt     DateTime       @default(now())
  company       Company        @relation(fields: [companyId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  department    Department?    @relation(fields: [departmentId], references: [id])
  attendance    Attendance[]
  leaves        Leave[]
  leaveBalances LeaveBalance[]
  payrolls      Payroll[]
}

model CompanySettings {
  id          Int      @id @default(autoincrement())
  companyId   Int      @unique
  workingDays String   @default("1,2,3,4,5") // 0=Sun,1=Mon,...,6=Sat
  timezone    String   @default("Asia/Karachi")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])
}

model PublicHoliday {
  id        Int      @id @default(autoincrement())
  companyId Int
  name      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
}

model ShiftSchedule {
  id           Int         @id @default(autoincrement())
  companyId    Int
  departmentId Int?
  name         String
  shiftStart   String
  shiftEnd     String
  gracePeriod  Int         @default(30)
  isActive     Boolean     @default(true)
  createdById  Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  company      Company     @relation(fields: [companyId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
}

model DeductionRule {
  id               Int      @id @default(autoincrement())
  companyId        Int
  type             String   // LATE_ARRIVAL | HALF_DAY | UNAPPROVED_LEAVE
  deductPercentage Float    @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  company          Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, type])
}

model Attendance {
  id        Int       @id @default(autoincrement())
  companyId Int
  employeeId Int
  date      DateTime
  checkIn   DateTime?
  checkOut  DateTime?
  status    String
  createdAt DateTime  @default(now())
  company   Company   @relation(fields: [companyId], references: [id])
  employee  Employee  @relation(fields: [employeeId], references: [id])
}

model Leave {
  id         Int      @id @default(autoincrement())
  companyId  Int
  employeeId Int
  leaveType  String
  startDate  DateTime
  endDate    DateTime
  days       Int
  reason     String?
  status     String   @default("pending")
  approvedBy Int?
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model LeaveBalance {
  id         Int      @id @default(autoincrement())
  companyId  Int
  employeeId Int
  leaveType  String
  total      Int      @default(0)
  used       Int      @default(0)
  remaining  Int      @default(0)
  year       Int
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Payroll {
  id         Int      @id @default(autoincrement())
  companyId  Int
  employeeId Int
  month      Int
  year       Int
  basic      Float
  allowances Float    @default(0)
  deductions Float    @default(0)
  netSalary  Float
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])
}
